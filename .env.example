# Copy this file to .env and fill in your key.
# OpenRouter API key -- get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-c58cf71d0d150f13bfda3c7aab3cdaa8b2bd990a3995d803a63ac4b6bc8b930d1

# Optional: override the extraction model (any OpenRouter model string).
BILL_ORGANIZER_MODEL=OPENROUTER/nvidia/nemotron-3-super-120b-a12b:free

# OCR engine for image bills: "tesseract" (default, light) or "paddle"
# (heavier but more accurate on real-world receipts).
# Paddle requires the extra install: pip install -e ".[paddle]"
OCR_ENGINE=tesseract
#OCR_ENGINE=paddle

